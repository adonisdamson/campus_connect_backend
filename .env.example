# ─── Server ────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=3000

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── JWT ───────────────────────────────────────────────────────
# REQUIRED. In production the server refuses to boot if this is unset or
# shorter than 32 chars. Generate one with:  openssl rand -hex 48
JWT_SECRET=replace_with_64_char_random_string

# ─── Firebase (Google sign-in token verification, optional) ────
# Enables POST /auth/google. Leave blank to disable Google sign-in.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ─── Paystack (payments) ───────────────────────────────────────
# When set (sk_test_/sk_live_), wallet top-up + /payments/* go live and the
# webhook signature is verified. WITHOUT it, top-up instant-credits the wallet
# in dev only — in production an unconfigured top-up returns 503 and unsigned
# webhooks are rejected.
PAYSTACK_SECRET_KEY=sk_test_xxx

# ─── CORS / realtime origin ────────────────────────────────────
# In production this MUST be explicit origin(s); "*" is refused at boot.
# Comma-separate multiple origins: https://app.campusconnect.gh,https://admin.campusconnect.gh
FRONTEND_URL=*

# ─── Auth toggles ──────────────────────────────────────────────
# Guest sign-in is enabled in dev. To allow it in production, set this true.
ALLOW_GUEST=false

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
